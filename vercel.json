{
  "installCommand": "echo \"Skipping dependency install; using committed static bundle\"",
  "buildCommand": "echo \"Using committed static bundle\"",
  "outputDirectory": "vercel-static",
  "rewrites": [
    {
      "source": "/map",
      "destination": "/index.html"
    },
    {
      "source": "/news",
      "destination": "/index.html"
    },
    {
      "source": "/compare",
      "destination": "/index.html"
    },
    {
      "source": "/methodology",
      "destination": "/index.html"
    },
    {
      "source": "/commodity/:path*",
      "destination": "/index.html"
    }
  ]
}
